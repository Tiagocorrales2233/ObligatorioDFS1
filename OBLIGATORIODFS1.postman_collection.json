                  "pm.test('Status 201', function () { pm.response.to.have.status(201); });",
                  "const json = pm.response.json();",
                  "pm.test('Tiene token y usuario', function () {",
                  "  pm.expect(json).to.have.property('token');",
                  "  pm.expect(json).to.have.property('usuario');",
