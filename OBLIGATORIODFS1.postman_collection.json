              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('adminToken', json.token);",
                  "const payload = JSON.parse(atob(json.token.split('.')[1].replace(/-/g, '+').replace(/_/g, '/')));",
                  "pm.collectionVariables.set('adminId', payload.id);",
                  "pm.test('Admin token guardado', function () {",
                  "  pm.expect(pm.collectionVariables.get('adminToken')).to.be.a('string').and.not.empty;",
                  "});"
                ]
              }
            }
